# ===========================================
#  Shuati Production Environment Variables
#  部署命令: cp .env.production .env 并填入真实值
#  警告: .env 已被 gitignore，请勿提交真实密码
# ===========================================

# MySQL
MYSQL_ROOT_PASSWORD=<强密码>
MYSQL_USER=root
MYSQL_PASSWORD=<强密码>

# Backend
SERVER_PORT=8080
LOG_LEVEL=INFO

# WeChat Mini-Program
WECHAT_APPID=<你的小程序AppID>
WECHAT_SECRET=<你的小程序Secret>
