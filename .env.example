# MySQL 配置（后端 + Docker Compose 共用）
MYSQL_URL=jdbc:mysql://localhost:3306/shuati?useUnicode=true&characterEncoding=UTF-8&serverTimezone=Asia/Shanghai&useSSL=false&connectionCollation=utf8mb4_unicode_ci
MYSQL_USER=root
MYSQL_PASSWORD=你的本地MySQL密码
MYSQL_ROOT_PASSWORD=你的本地MySQL root密码

# RabbitMQ 配置
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=你的RabbitMQ用户名
RABBITMQ_PASSWORD=你的RabbitMQ密码
RABBITMQ_DEFAULT_USER=shuati
RABBITMQ_DEFAULT_PASS=你的RabbitMQ默认密码

# 后端服务端口
SERVER_PORT=8080

# 前端请求的后端地址（Taro 会以 TARO_APP_ 前缀注入）
TARO_APP_API_URL=http://localhost:8080
